{
  "schema_version": 1,
  "repository": "tldraw/tldraw",
  "observed_date": "2026-07-18",
  "sources": {
    "agents": "https://raw.githubusercontent.com/tldraw/tldraw/main/AGENTS.md",
    "package": "https://raw.githubusercontent.com/tldraw/tldraw/main/package.json",
    "contributing": "https://raw.githubusercontent.com/tldraw/tldraw/main/CONTRIBUTING.md"
  },
  "requirements": {
    "package_manager": "yarn@4.12.0",
    "node": ">=22.12.0",
    "run_from": "repository root",
    "bare_tsc_allowed": false,
    "targeted_checks_first": true
  },
  "contribution_policy": "issues-only",
  "policy_note": "Upstream currently does not accept pull requests; use an issue and link a fork branch when code helps the report.",
  "dry_run_commands": [
    "corepack enable",
    "yarn --version",
    "yarn install --immutable",
    "yarn test <target-test-file> --run",
    "yarn typecheck",
    "yarn lint-current",
    "yarn api-check"
  ],
  "forbidden_shortcuts": [
    "npm run <repo-script>",
    "bare tsc",
    "repo-wide e2e without a scoped reason",
    "opening a pull request while upstream contributions are disabled"
  ]
}
