      "allowed_extra_routes": [],
      "max_routes": 1,
      "assertions": [
        "uses_Driver_from_at_tldraw_driver",
        "calls_dispose",
        "screen_vs_page_coordinates_aware"
      ],
      "evidence_markers": {
        "uses_Driver_from_at_tldraw_driver": ["@tldraw/driver", "Driver"],
        "calls_dispose": ["dispose"],
        "screen_vs_page_coordinates_aware": ["screen", "page"]
      }
    },
