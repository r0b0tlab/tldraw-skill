{
  "version": 2,
  "skill": "tldraw",
  "description": "Activation precision and routing evaluation cases for the tldraw Hermes skill",
  "scoring": {
    "require_explicit_activation_on_positive": true,
    "forbid_auto_select_on_negative": true,
    "require_exact_expected_routes": true,
    "allow_only_explicit_extra_routes": true,
    "cap_route_count": true,
    "require_evidence_markers": true,
    "require_version_inspect_before_api_advice": true,
    "prove_skill_load_via_session_tool_traces_when_available": true,
    "notes": [
      "expected_routes must match exactly; only allowed_extra_routes may be added",
      "max_routes defaults to |expected ∪ allowed_extras|",
      "evidence values must contain every listed marker for that assertion (case-insensitive substring)",
      "activate_tldraw self-report is never treated as skill-load proof",
      "when session_id is available, skill_view(tldraw) is verified from profile state.db tool traces"
    ]
  },
  "cases": [
    {
      "id": "pos-tldr-flowchart",
      "type": "positive",
      "prompt": "Generate a .tldr flowchart for our signup funnel using tldraw.",
      "expect_activate": true,
      "expected_routes": [
        "references/diagram-authoring.md",
        "references/data-files-assets-export-mermaid.md"
      ],
      "allowed_extra_routes": [
        "references/shapes-tools-bindings.md",
        "references/project-routing-and-starters.md"
      ],
      "max_routes": 4,
      "assertions": [
        "uses_editor_serializer_not_python_records",
        "uses_geo_and_toRichText",
        "uses_bindings_for_arrows",
        "inspect_project_or_scaffold_first"
      ],
      "evidence_markers": {
        "uses_editor_serializer_not_python_records": ["serializeTldrawJson", "Editor"],
        "uses_geo_and_toRichText": ["geo", "toRichText"],
        "uses_bindings_for_arrows": ["binding"],
        "inspect_project_or_scaffold_first": ["inspect"]
      }
    },
    {
      "id": "pos-add-to-react-app",
      "type": "positive",
      "prompt": "Add tldraw to my existing Vite React app as a full-page whiteboard.",
      "expect_activate": true,
      "expected_routes": [
        "references/project-routing-and-starters.md"
      ],
      "allowed_extra_routes": [],
      "max_routes": 1,
      "assertions": [
        "installs_tldraw_not_legacy_alias",
        "imports_tldraw_css",
        "container_has_explicit_size",
        "runs_inspect_project"
      ],
      "evidence_markers": {
        "installs_tldraw_not_legacy_alias": ["tldraw", "@tldraw/tldraw"],
        "imports_tldraw_css": ["tldraw.css"],
        "container_has_explicit_size": ["100%"],
        "runs_inspect_project": ["inspect_project"]
      }
    },
    {
      "id": "pos-driver-automate",
      "type": "positive",
      "prompt": "Automate the tldraw editor with @tldraw/driver to draw and select shapes in tests.",
      "expect_activate": true,
      "expected_routes": [
