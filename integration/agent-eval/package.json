{
	"name": "tldraw-agent-eval",
	"version": "0.0.0",
	"private": true,
	"type": "module",
	"scripts": {
		"build": "vite build",
		"dev": "vite --host",
		"preview": "vite preview",
		"typecheck": "tsc --noEmit",
		"test": "node --import tsx --test harness/tests/*.test.ts",
		"test:harness": "node --import tsx --test harness/tests/*.test.ts",
		"migrate:legacy": "tsx scripts/migrate-legacy.ts",
		"scan:bundle": "tsx scripts/scan-bundle-secrets.ts",
		"eval": "tsx scripts/run-eval.ts",
		"verify": "npm run test && npm run typecheck && npm run build && npm run scan:bundle && npm run migrate:legacy"
	},
	"dependencies": {
		"@ai-sdk/anthropic": "^2.0.2",
		"@ai-sdk/google": "^2.0.14",
		"@ai-sdk/openai": "^2.0.24",
		"@cloudflare/vite-plugin": "^1.29.1",
		"@google/generative-ai": "^0.24.1",
		"@tldraw/tlschema": "5.2.5",
		"@worker-tools/json-stream": "^0.1.0-pre.12",
		"ai": "^5.0.63",
		"best-effort-json-parser": "^1.1.3",
		"itty-router": "^5.0.18",
		"react": "^19.2.1",
		"react-dom": "^19.2.1",
		"react-markdown": "^10.1.0",
		"tldraw": "5.2.5",
		"wrangler": "^4.75.0",
		"zod": "^4.1.8"
	},
	"devDependencies": {
		"@cloudflare/workers-types": "^5.20260714.1",
		"@types/react": "^19.2.7",
		"@types/react-dom": "^19.2.3",
		"@vitejs/plugin-react": "^6.0.1",
		"typescript": "^5.8.3",
		"vite": "^8.0.16",
		"tsx": "^4.23.1",
		"@types/node": "^24.13.3"
	},
	"description": "Repository-owned tldraw 5.2.5 agent starter evaluation harness (no provider credentials required)"
}