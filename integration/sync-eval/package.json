{
  "name": "tldraw-sync-eval",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "Repository-owned two-client tldraw 5.2.5 self-hosted sync harness (official simple-server pattern + auth + persistence eval)",
  "scripts": {
    "dev": "concurrently -n server,client -c red,blue \"npm run dev:server\" \"npm run dev:client\"",
    "dev:server": "tsx watch src/server/server.ts",
    "dev:client": "vite --host 127.0.0.1",
    "typecheck": "tsc -p tsconfig.json --noEmit --pretty false",
    "build": "tsc -p tsconfig.json --noEmit --pretty false && vite build",
    "test:unit": "tsx tests/security.unit.test.ts",
    "test:integration": "tsx tests/sync.integration.test.ts",
    "test": "npm run typecheck && npm run test:unit && npm run test:integration",
    "verify": "npm run build && npm run test:unit && npm run test:integration"
  },
  "dependencies": {
    "@fastify/cors": "^11.3.0",
    "@fastify/websocket": "^11.0.0",
    "@tldraw/sync": "5.2.5",
    "@tldraw/sync-core": "5.2.5",
    "@tldraw/tlschema": "5.2.5",
    "better-sqlite3": "^11.10.0",
    "fastify": "^5.8.1",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "tldraw": "5.2.5",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.12",
    "@types/node": "^24.13.3",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^6.0.3",
    "concurrently": "^9.1.2",
    "playwright": "^1.61.1",
    "tsx": "^4.23.1",
    "typescript": "~5.9.3",
    "vite": "^8.1.1"
  }
}
