# Dev-only auth token accepted by the local sync server.
# Never ship this harness token pattern as production auth.
# Non-loopback SYNC_HOST is refused while this default token is in use.
SYNC_AUTH_TOKEN=harness-ok
SYNC_PORT=5858
SYNC_HOST=127.0.0.1
# Optional extra CORS origins (comma-separated). Loopback origins are allowed by default.
# SYNC_CORS_ORIGINS=https://app.example
VITE_SYNC_HTTP_URL=http://127.0.0.1:5858
ROOMS_DIR=.rooms
ASSETS_DIR=.assets
