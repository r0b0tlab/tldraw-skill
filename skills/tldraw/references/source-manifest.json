        {
          "source": "https://tldraw.dev/blog/20-things-i-wish-ai-chatbots-knew-about-tldraw",
          "summary": "Commercial license has no analytics SDK; anonymous usage via static asset requests and hobby watermark image; self-host static assets on commercial for no external requests."
        }
